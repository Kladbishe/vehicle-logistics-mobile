# Google Service Account — for Google Sheets only
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Sheets ID (from spreadsheet URL)
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Google Drive — OAuth2 for personal account (run: node scripts/get-drive-token.mjs)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_OAUTH_REFRESH_TOKEN=  # auto-filled by setup script

# Google Drive root folder ID (the "cars" folder in your personal Drive)
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here
